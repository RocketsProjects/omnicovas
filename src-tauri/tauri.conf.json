{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "OmniCOVAS",
  "version": "0.1.0",
  "identifier": "com.rocketsprojects.omnicovas",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "OmniCOVAS",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "center": true
      },
      {
        "label": "overlay",
        "title": "OmniCOVAS Overlay",
        "width": 400,
        "height": 120,
        "transparent": true,
        "alwaysOnTop": true,
        "decorations": false,
        "skipTaskbar": true,
        "resizable": false,
        "focus": false,
        "visible": false,
        "x": 100,
        "y": 100
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
  "active": true,
  "targets": "all",
  "externalBin": [
    "bin/omnicovas-sidecar"
  ],
  "icon": [
    "icons/32x32.png",
    "icons/128x128.png",
    "icons/128x128@2x.png",
    "icons/icon.icns",
    "icons/icon.ico"
  ]
}
}
